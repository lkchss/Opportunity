# Copy this file to .env and set what you need. Never commit .env to git.
#
# Pick a backend. The finder splits search (DuckDuckGo, no key) from reasoning
# (the model below), so any chat model can rank results — or run with none.
#
#   LLM_PROVIDER = anthropic | openai | none
#     anthropic → Claude API (also enables Claude's native web search)
#     openai    → OpenAI *or any OpenAI-compatible endpoint* (set LLM_BASE_URL)
#     none      → no model; DuckDuckGo keyword results only
#
# Leave LLM_PROVIDER unset to auto-detect from whichever API key is present.
LLM_PROVIDER=anthropic

# Model id (provider-specific). Defaults: anthropic→claude-opus-4-8,
# openai→gpt-4o-mini. For a local model set the name your server exposes.
# LLM_MODEL=claude-opus-4-8

# Base URL — the lever for local / alternative hosts (openai provider only):
#   Ollama    → http://localhost:11434/v1   (LLM_MODEL=llama3.1, etc.)
#   LM Studio → http://localhost:1234/v1
#   OpenRouter→ https://openrouter.ai/api/v1
# LLM_BASE_URL=

# API key. Falls back to ANTHROPIC_API_KEY / OPENAI_API_KEY below if unset.
# Local servers don't need one.
# LLM_API_KEY=

ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Set to 0 to make the anthropic provider rank DuckDuckGo results instead of
# running Claude's native web search.
# ANTHROPIC_WEB_SEARCH=1
